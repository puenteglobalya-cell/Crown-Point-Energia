# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service role key — server-only, NEVER expose to client bundles
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Comma-separated list of admin emails that can access /admin
CMS_ADMIN_EMAILS=admin@crownpointenergy.com,otro@crownpointenergy.com

# Resend — email notifications when a report is published
# Get your API key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Crown Point Energía <reportes@crownpointenergy.com>

# Push notifications — VAPID keys for web push
# Generate with: node -e "const webpush = require('web-push'); const keys = webpush.generateVAPIDKeys(); console.log('PUBLIC:', keys.publicKey); console.log('PRIVATE:', keys.privateKey)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@crownpointenergy.com

# Chromium for infografia PNG generation (Vercel only)
# URL to downloaded chromium binary from @sparticuz/chromium releases
CHROMIUM_URL=https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.tar

NEXT_PUBLIC_SITE_URL=https://crown-point-energia.vercel.app

# Cron secret — must match Authorization: Bearer token Vercel sends to /api/cron/* routes
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here

# Upstash Redis — distributed rate limiting (optional; in-memory fallback used if not set)
# Create a Redis database at https://console.upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here
