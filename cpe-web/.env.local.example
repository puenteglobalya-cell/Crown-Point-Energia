# Supabase — get these from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service role key — server-only, NEVER expose to client bundles
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Comma-separated list of admin emails that can access /admin
CMS_ADMIN_EMAILS=admin@crownpointenergy.com,otro@crownpointenergy.com

# Resend — email notifications when a report is published
# Get your API key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Crown Point Energía <reportes@crownpointenergy.com>

# Push notifications — VAPID keys for web push
# Generate with: node -e "const webpush = require('web-push'); const keys = webpush.generateVAPIDKeys(); console.log('PUBLIC:', keys.publicKey); console.log('PRIVATE:', keys.privateKey)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BDddCGkFNkL-xE2YM1kkiZsY9vbjTQux6Y4xMX-IQtc8UKpCcX877Rt5yUmmIMMKAwy8ChyfojFq9OWXgNb1_rM
VAPID_PRIVATE_KEY=7HhBzVPVd5vBl67rmaKfur4NZG7GIpevae-mBS6I9dk
VAPID_SUBJECT=mailto:admin@crownpointenergy.com

